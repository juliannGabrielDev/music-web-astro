---
// Import all requested organic shapes
import shapeCookie4 from '@/assets/figures/sided-cookie-4.svg';
import shapeSoftBoom from '@/assets/figures/soft-boom.svg';
import shapeFlower from '@/assets/figures/flower.svg';
import shapeGum from '@/assets/figures/Gum.svg';
import shapeGhost from '@/assets/figures/ghost-ish.svg';
import shapePill from '@/assets/figures/pill.svg';
import shapeCircle from '@/assets/figures/Circle.svg';
import shapeSquare from '@/assets/figures/Square.svg';
import shapeArrow from '@/assets/figures/arrow.svg';
import shapePixelCircle from '@/assets/figures/pixel-circle.svg';
import shapePuffyDiamond from '@/assets/figures/puffy-diamond.svg';
import shapeCookie12 from '@/assets/figures/sided-cookie-12.svg';
import shapeTriangle from '@/assets/figures/triangle.svg';

import Adele from '@/assets/artists/adele.jpg';
import AmyWinehouse from '@/assets/artists/amy-winehouse.webp';
import CarlyRaeJepsen from '@/assets/artists/carly-rae-jepsen.webp';
import LadyGaga from '@/assets/artists/lady-gaga.webp';
import LanaDelRey from '@/assets/artists/lana-del-rey.jpg';
import MeghanTrainor from '@/assets/artists/meghan-trainor.png';
import Raye from '@/assets/artists/raye.webp';
import Top from '@/assets/artists/top.jpg';
import Twice from '@/assets/artists/twice.webp';
import OliviaDean from '@/assets/artists/olivia-dean.webp';
import ColdPlay from '@/assets/artists/cold-play.webp';
import Pink from '@/assets/artists/pink.webp';
import RobbieWilliams from '@/assets/artists/robbie-williams.jpg';
import SpiceGirls from '@/assets/artists/spice-girls.jpg';
import BritneySpears from '@/assets/artists/britney-spears.jpg';
import Aurora from '@/assets/artists/aurora.webp';
import ConanGray from '@/assets/artists/conan-gray.jpg';
import KatyPerry from '@/assets/artists/katy-perry.webp';

const baseSlides = [
	{
		type: 'single',
		shape: shapePixelCircle.src,
		item: { img: Adele.src, bg: 'bg-zinc-800' },
	},
	{
		type: 'quad',
		items: [
			{
				img: Raye.src,
				bg: 'bg-blue-500',
				shape: shapeCookie4.src,
			},
			{
				img: AmyWinehouse.src,
				bg: 'bg-yellow-400',
				shape: shapeSoftBoom.src,
			},
			{
				img: CarlyRaeJepsen.src,
				bg: 'bg-red-600',
				shape: shapeFlower.src,
			},
			{
				img: LadyGaga.src,
				bg: 'bg-emerald-500',
				shape: shapeGum.src,
			},
		],
	},
	{
		type: 'single',
		shape: shapeGhost.src,
		item: { img: LanaDelRey.src, bg: 'bg-yellow-500' },
	},
	{
		type: 'quad',
		items: [
			{
				img: SpiceGirls.src,
				bg: 'bg-purple-500',
				shape: shapeGhost.src,
			},
			{
				img: RobbieWilliams.src,
				bg: 'bg-orange-500',
				shape: shapePill.src,
			},
			{
				img: Pink.src,
				bg: 'bg-teal-500',
				shape: shapeCircle.src,
			},
			{
				img: ColdPlay.src,
				bg: 'bg-indigo-500',
				shape: shapeSquare.src,
			},
		],
	},
	{
		type: 'single',
		shape: shapeFlower.src,
		item: { img: OliviaDean.src, bg: 'bg-pink-500' },
	},
	{
		type: 'single',
		shape: shapeArrow.src,
		item: { img: MeghanTrainor.src, bg: 'bg-emerald-600' },
	},
	{
		type: 'quad',
		items: [
			{
				img: KatyPerry.src,
				bg: 'bg-zinc-700',
				shape: shapePixelCircle.src,
			},
			{
				img: BritneySpears.src,
				bg: 'bg-rose-500',
				shape: shapePuffyDiamond.src,
			},
			{
				img: Aurora.src,
				bg: 'bg-amber-500',
				shape: shapeCookie12.src,
			},
			{
				img: ConanGray.src,
				bg: 'bg-cyan-500',
				shape: shapeTriangle.src,
			},
		],
	},
	{
		type: 'single',
		shape: shapePill.src,
		item: { img: Twice.src, bg: 'bg-indigo-700' },
	},
	{
		type: 'single',
		shape: shapeCookie12.src,
		item: { img: Top.src, bg: 'bg-blue-700' },
	},
];

const slides = [...baseSlides, ...baseSlides];
---

<div
	class="artists-section flex flex-col items-center justify-center w-full min-h-150 py-16 relative overflow-hidden bg-zinc-950 text-white select-none"
>
	<h1
		class="h1 mb-12 uppercase relative z-10 pointer-events-none"
	>
		Artistas
	</h1>

	<div
		class="carousel-container w-full relative touch-pan-y cursor-grab active:cursor-grabbing"
		data-base-count={baseSlides.length}
	>
		<div class="carousel-track relative w-full h-87.5 md:h-125">
			{
				slides.map((slide, index) => (
					<div class="custom-slide absolute left-1/2 top-1/2 w-62.5 h-65.5 md:w-100 md:h-100">
						{slide.type === 'single' ? (
							<div
								class={`artist-figure w-full h-full overflow-hidden flex items-center justify-center relative shadow-2xl transition-shadow duration-300 ${slide.item!.bg}`}
								style={`mask-image: url(${slide.shape}); mask-size: contain; mask-repeat: no-repeat; mask-position: center; -webkit-mask-image: url(${slide.shape}); -webkit-mask-size: contain; -webkit-mask-repeat: no-repeat; -webkit-mask-position: center;`}
							>
								<img
									src={slide.item!.img}
									alt={`Artist ${index + 1}`}
									class="w-full h-full object-cover pointer-events-none"
									draggable="false"
								/>
							</div>
						) : (
							<div class="w-full h-full grid grid-cols-2 grid-rows-2 gap-2 md:gap-4 p-1">
								{slide.items!.map((subItem, subIndex) => (
									<div
										class={`artist-figure w-full h-full overflow-hidden relative shadow-lg ${subItem.bg}`}
										style={`mask-image: url(${subItem.shape}); mask-size: contain; mask-repeat: no-repeat; mask-position: center; -webkit-mask-image: url(${subItem.shape}); -webkit-mask-size: contain; -webkit-mask-repeat: no-repeat; -webkit-mask-position: center;`}
									>
										<img
											src={subItem.img}
											alt={`Artist from group ${index + 1}`}
											class="w-full h-full object-cover pointer-events-none"
											draggable="false"
										/>
									</div>
								))}
							</div>
						)}
					</div>
				))
			}
		</div>
	</div>

	<div class="w-full max-w-4xl mx-auto mt-16 px-6 flex flex-col items-center">
		<div class="w-24 h-1 bg-yellow-400 rounded-full opacity-30 pointer-events-none"></div>

		<p
			class="mt-8 text-zinc-400 text-sm md:text-base text-center max-w-sm tracking-wide leading-relaxed pointer-events-none"
		>
			Los que traen arte a la gente<br />
			Con los ojos abiertos y los oidos abiertos
		</p>
	</div>
</div>

<style>
	.custom-slide {
		will-change: transform, z-index, opacity;
	}

	.custom-slide.active .artist-figure {
		box-shadow: 0 0 80px -20px rgba(255, 255, 255, 0.4);
	}
</style>

<script>
	import { gsap } from 'gsap';

	gsap.from('.h1', {
		x: -100,
		skewY: 10,
		opacity: 0,
		duration: 1.3,
		ease: 'elastic.out(1, 0.5)',
	});

	class InfiniteCarousel {
		private track: HTMLElement | null;
		private slides: HTMLElement[];
		private N: number;
		private container: HTMLElement | null;
		private baseCount: number;
		private offset: number;
		private targetOffset: number;
		private isDragging: boolean;
		private startX: number;
		private startOffset: number;
		private spacing: number;
		private scaleFactor: number;

		constructor() {
			this.track = document.querySelector('.carousel-track');
			if (!this.track) {
				this.slides = [];
				this.N = 0;
				this.container = null;
				this.baseCount = 0;
				this.offset = 0;
				this.targetOffset = 0;
				this.isDragging = false;
				this.startX = 0;
				this.startOffset = 0;
				this.spacing = 0;
				this.scaleFactor = 0;
				return;
			}

			this.slides = Array.from(this.track.querySelectorAll('.custom-slide')) as HTMLElement[];
			this.N = this.slides.length;
			if (this.N === 0) {
				this.container = null;
				this.baseCount = 0;
				this.offset = 0;
				this.targetOffset = 0;
				this.isDragging = false;
				this.startX = 0;
				this.startOffset = 0;
				this.spacing = 0;
				this.scaleFactor = 0;
				return;
			}

			this.container = document.querySelector('.carousel-container');
			this.baseCount = parseInt(this.container?.getAttribute('data-base-count') || '9');

			this.offset = 0;
			this.targetOffset = 0;
			this.isDragging = false;
			this.startX = 0;
			this.startOffset = 0;

			this.spacing = window.innerWidth < 768 ? 250 : 400;
			this.scaleFactor = 0.15;

			this.bindEvents();
			this.render();
			this.animate();
		}

		bindEvents() {
			if (!this.container) return;
			this.container.addEventListener('touchstart', (e: TouchEvent) => this.onStart(e.touches[0].clientX), {
				passive: true,
			});
			this.container.addEventListener(
				'touchmove',
				(e: TouchEvent) => {
					if (this.isDragging) {
						e.preventDefault();
						this.onMove(e.touches[0].clientX);
					}
				},
				{ passive: false }
			);
			this.container.addEventListener('touchend', () => this.onEnd());

			this.container.addEventListener('mousedown', (e: MouseEvent) => {
				e.preventDefault();
				this.onStart(e.clientX);
			});
			document.addEventListener('mousemove', (e: MouseEvent) => this.onMove(e.clientX));
			document.addEventListener('mouseup', () => this.onEnd());

			window.addEventListener('resize', () => {
				this.spacing = window.innerWidth < 768 ? 250 : 400;
				this.render();
			});
		}

		onStart(x: number) {
			if (!this.container) return;
			this.isDragging = true;
			this.startX = x;
			this.startOffset = this.offset;
			this.targetOffset = this.offset;
			this.container.style.cursor = 'grabbing';
		}

		onMove(x: number) {
			if (!this.isDragging) return;
			const dx = x - this.startX;
			const dragFactor = window.innerWidth < 768 ? 250 : 400;
			this.targetOffset = this.startOffset - dx / dragFactor;
		}

		onEnd() {
			if (!this.isDragging || !this.container) return;
			this.isDragging = false;
			this.targetOffset = Math.round(this.targetOffset);
			this.container.style.cursor = 'grab';
		}

		animate() {
			if (!this.isDragging) {
				this.offset += (this.targetOffset - this.offset) * 0.1;
			} else {
				this.offset = this.targetOffset;
			}

			this.render();
			requestAnimationFrame(() => this.animate());
		}

		render() {
			this.slides.forEach((slide, i) => {
				let diff = i - this.offset;
				diff = diff - Math.round(diff / this.N) * this.N;
				const absDiff = Math.abs(diff);

				const x = diff * this.spacing;
				const scale = Math.max(0, 1 - absDiff * this.scaleFactor);
				const zIndex = 100 - Math.round(absDiff * 10);
				const opacity = absDiff > 4 ? 0 : 1;

				slide.style.transform = `translate(-50%, -50%) translateX(${x}px) scale(${scale})`;
				slide.style.zIndex = zIndex.toString();
				slide.style.opacity = opacity.toString();

				if (absDiff < 0.1) {
					slide.classList.add('active');
				} else {
					slide.classList.remove('active');
				}
			});
		}
	}

	document.addEventListener('DOMContentLoaded', () => {
		new InfiniteCarousel();
	});
</script>
