---
import '@/global.css';
import { ClientRouter } from 'astro:transitions';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import Loader from '@/components/Loader.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="viewport"
			content="width=device-width"
		/>
		<link
			rel="icon"
			type="image/svg+xml"
			href="/favicon.svg"
		/>
		<link
			rel="icon"
			href="/favicon.ico"
		/>
		<meta
			name="generator"
			content={Astro.generator}
		/>
		<title>Música</title>
		<ClientRouter />
	</head>
	<body class="bg-zinc-950">
		<span
			id="start"
			aria-hidden="true"
		></span>
		<Navbar />
		<slot />
		<Footer />
		<Loader />

		<a
			href="#start"
			class="back-to-top"
		>
			<svg
				class="h-full w-full"
				viewBox="0 0 316 278"
				fill="none"
				xmlns="http://www.w3.org/2000/svg"
			>
				<path
					d="M271.57 122.2C257.552 100.62 243.535 79.01 229.517 57.43C220.423 43.42 211.167 29.2202 198.872 18.0902C186.576 6.94018 170.648 -0.939823 154.316 0.0901773C139.976 1.01018 126.684 8.72013 116.191 18.7901C105.698 28.8601 97.546 41.2601 89.528 53.5401C67.842 86.7201 46.13 119.9 24.444 153.1C14.139 168.86 3.56499 185.31 0.712987 204.09C-2.73101 226.78 6.55198 249.89 23.018 264.98C40.237 280.76 68.138 279.48 89.098 275.16C112.075 270.41 134.541 261.48 157.975 261.51C178.047 261.51 197.446 268.11 216.979 272.91C236.485 277.68 257.445 280.62 276.279 273.52C299.659 264.73 316.448 239.73 315.991 214.07C315.56 190.66 302.457 169.75 289.839 150.27C283.758 140.92 277.678 131.55 271.597 122.2H271.57Z"
					fill="#d4d4d8"
				></path>
			</svg>

			<span class="sr-only">Volver arriba</span>
		</a>

		<style>
			@reference "tailwindcss";
			@reference "@/global.css";

			html {
				container-type: scroll-state;
				container-name: scroller;
				scroll-behavior: smooth;
				scroll-padding-top: 80px;
			}
			body {
				@apply font-body;
			}

			.back-to-top {
				@apply fixed right-4 bottom-4 z-50 size-13 bg-zinc-800 p-3 text-white transition-all duration-300 hover:bg-zinc-700;
				border-radius: 28px;
				corner-shape: squircle;

				@container scroller not scroll-state(scrollable: top) {
					opacity: 0;
					pointer-events: none;
					transform: translateY(10px);
				}
			}
		</style>

		<script>
			const scrollMemory: Record<string, number> = {};

			document.addEventListener('astro:before-preparation', () => {
				// Guardar posición de scroll de la página que se va a dejar
				scrollMemory[location.href] = window.scrollY;

				const loader = document.querySelector('.loader');
				if (loader) {
					loader.classList.add('loader--active');
				}
			});

			document.addEventListener('astro:page-load', () => {
				const loader = document.querySelector('.loader');
				if (loader) {
					loader.classList.remove('loader--active');
				}

				// Restaurar scroll si existe posición guardada para esta URL
				const saved = scrollMemory[location.href];
				if (saved) {
					window.scrollTo({ top: saved, behavior: 'instant' });
				}
			});
		</script>
	</body>
</html>
