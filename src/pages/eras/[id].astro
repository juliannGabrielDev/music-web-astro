---
import Layout from '@/layouts/Layout.astro';
import ShapeCircle from '@/assets/figures/Circle.svg';
import ShapeSquare from '@/assets/figures/Square.svg';
import ShapeTriangle from '@/assets/figures/triangle.svg';
import ShapePuffyDiamond from '@/assets/figures/puffy-diamond.svg';
import ShapePixelCircle from '@/assets/figures/pixel-circle.svg';
import ShapeFlower from '@/assets/figures/flower.svg';
import ShapeSoftBoom from '@/assets/figures/soft-boom.svg';
import { eras } from '@/data/eras';
import EraAntiguedad from '@/assets/eras/musica-antiguedad.webp';
import EraEdadMedia from '@/assets/eras/musica-edad-media.webp';
import EraRenacimiento from '@/assets/eras/musica-renacimiento.webp';
import EraBarroco from '@/assets/eras/musica-barroco.webp';
import EraClasicismo from '@/assets/eras/musica-clasicismo.webp';
import EraRomanticismo from '@/assets/eras/musica-romanticismo.webp';
import EraSigloXX from '@/assets/eras/musica-siglo-xx.webp';

export function getStaticPaths() {
	return eras.map((era) => ({
		params: { id: era.id },
		props: { era },
	}));
}

const { era } = Astro.props;

const eraMaskMap = {
	circle: ShapeCircle.src,
	square: ShapeSquare.src,
	triangle: ShapeTriangle.src,
	puffyDiamond: ShapePuffyDiamond.src,
	pixelCircle: ShapePixelCircle.src,
	flower: ShapeFlower.src,
	softBoom: ShapeSoftBoom.src,
};

const eraImageMap = {
	'musica-antiguedad': EraAntiguedad,
	'musica-edad-media': EraEdadMedia,
	'musica-renacimiento': EraRenacimiento,
	'musica-barroco': EraBarroco,
	'musica-clasicismo': EraClasicismo,
	'musica-romanticismo': EraRomanticismo,
	'musica-siglo-xx': EraSigloXX,
};

const maskSrc = eraMaskMap[era.maskKey];
const eraImageSrc = eraImageMap[era.imageKey].src;
const transitionName = `era-${era.id}`;
---

<Layout>
	<main class="detail-page">
		<a
			href="/"
			class="back-link"
			>← Volver</a
		>

		<article class="detail-article">
			<header class="detail-header">
				<p class="detail-eyebrow">Era Musical</p>
				<h1 class="detail-title">{era.name}</h1>
				<div class="detail-meta">
					<span>{era.years}</span>
				</div>
			</header>

			<div class="detail-image-wrap">
				<div
					class="detail-image bg-cover bg-center"
					style={`background-image: url('${eraImageSrc}')`}
					transition:name={transitionName}
				>
				</div>
				<!-- Overlays para oscurecer y dar textura -->
				<div class="absolute inset-0 bg-zinc-950/20 mix-blend-multiply transition-opacity duration-300"></div>
				<div
					class="absolute inset-0 opacity-20 mix-blend-overlay"
					style="background-image: linear-gradient(to right, rgba(230, 230, 230, 0.5) 1px, transparent 1px), linear-gradient(to bottom, rgba(230, 230, 230, 0.5) 1px, transparent 1px); background-size: 20px 20px;"
				>
				</div>

				<div
					class="detail-image-mask"
					style={`mask-image: url(${maskSrc}); mask-size: contain; mask-repeat: no-repeat; mask-position: center; -webkit-mask-image: url(${maskSrc}); -webkit-mask-size: contain; -webkit-mask-repeat: no-repeat; -webkit-mask-position: center;`}
				>
					<div
						class="detail-image-mask__img bg-cover bg-center"
						style={`background-image: url('${eraImageSrc}')`}
					>
					</div>
				</div>
			</div>

			<p class="detail-description">{era.extendedDesc}</p>
		</article>
	</main>
</Layout>

<style>
	@reference 'tailwindcss';
	@reference '@/global.css';

	.detail-page {
		@apply mx-auto max-w-3xl px-6 py-12;
	}

	.back-link {
		@apply mb-8 inline-block font-semibold text-zinc-400 no-underline transition-colors duration-200 hover:text-zinc-100;
	}

	.detail-article {
		@apply grid gap-6;
	}

	.detail-header {
		@apply grid gap-2;
	}

	.detail-eyebrow {
		@apply text-xs font-semibold tracking-widest text-purple-400 uppercase;
	}

	.detail-title {
		@apply font-display text-5xl leading-none text-zinc-100 md:text-7xl;
	}

	.detail-meta {
		@apply flex flex-wrap gap-2 text-sm font-semibold text-zinc-400;
	}

	.detail-meta > span {
		@apply rounded-full border border-purple-800 bg-purple-900/50 px-3 py-1 text-purple-200;
	}

	.detail-image-wrap {
		@apply relative mb-6 aspect-video w-full overflow-hidden rounded-3xl border border-zinc-800 bg-zinc-900;
	}

	.detail-image {
		@apply absolute inset-0 h-full w-full object-cover transition-transform duration-700 hover:scale-105;
	}

	.detail-image-mask {
		@apply pointer-events-none absolute inset-0 scale-125 opacity-40 blur-sm;
	}

	.detail-image-mask__img {
		@apply h-full w-full;
	}

	.detail-description {
		@apply text-lg leading-relaxed text-zinc-300;
	}
</style>
