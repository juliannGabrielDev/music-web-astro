---
import Layout from '../layouts/Layout.astro';
import HeroImage from '../assets/images/historia-musica-hero.webp';
import PixelTriangle from '../assets/figures/pixel-triangle.svg';
import ShapeCircle from '../assets/figures/Circle.svg';
import ShapeFlower from '../assets/figures/flower.svg';
import ShapeGhost from '../assets/figures/ghost-ish.svg';
import ShapePill from '../assets/figures/pill.svg';
import ShapeSoftBoom from '../assets/figures/soft-boom.svg';
import ShapeCookie4 from '../assets/figures/sided-cookie-4.svg';
import ShapeSquare from '../assets/figures/Square.svg';
import ShapeTriangle from '../assets/figures/triangle.svg';
import ShapePuffyDiamond from '../assets/figures/puffy-diamond.svg';
import ShapePixelCircle from '../assets/figures/pixel-circle.svg';
import { Image } from 'astro:assets';
import Card from '../components/Card.astro';
import { instruments } from '../data/instruments';
import { eras } from '../data/eras';

// Import instrument images
import ImageLaud from '../assets/instruments/laud.webp';
import ImageOrgano from '../assets/instruments/organo-de-tubos.webp';
import ImagePiano from '../assets/instruments/piano.webp';
import ImageSintetizador from '../assets/instruments/sintetizador.webp';
import ImageViolin from '../assets/instruments/violin.webp';

// Import era images
import EraAntiguedad from '../assets/eras/musica-antiguedad.webp';
import EraEdadMedia from '../assets/eras/musica-edad-media.webp';
import EraRenacimiento from '../assets/eras/musica-renacimiento.webp';
import EraBarroco from '../assets/eras/musica-barroco.webp';
import EraClasicismo from '../assets/eras/musica-clasicismo.webp';
import EraRomanticismo from '../assets/eras/musica-romanticismo.webp';
import EraSigloXX from '../assets/eras/musica-siglo-xx.webp';

const eraImageMap = {
	'musica-antiguedad': EraAntiguedad,
	'musica-edad-media': EraEdadMedia,
	'musica-renacimiento': EraRenacimiento,
	'musica-barroco': EraBarroco,
	'musica-clasicismo': EraClasicismo,
	'musica-romanticismo': EraRomanticismo,
	'musica-siglo-xx': EraSigloXX,
};

const instrumentImageMap = {
	laud: ImageLaud,
	'organo-de-tubos': ImageOrgano,
	piano: ImagePiano,
	sintetizador: ImageSintetizador,
	violin: ImageViolin,
};

const eraMaskMap = {
	circle: ShapeCircle.src,
	square: ShapeSquare.src,
	triangle: ShapeTriangle.src,
	puffyDiamond: ShapePuffyDiamond.src,
	pixelCircle: ShapePixelCircle.src,
	flower: ShapeFlower.src,
	softBoom: ShapeSoftBoom.src,
};

const maskMap = {
	circle: ShapeCircle.src,
	flower: ShapeFlower.src,
	ghost: ShapeGhost.src,
	pill: ShapePill.src,
	softBoom: ShapeSoftBoom.src,
};
---

<Layout>
	<section class="hero">
		<div class="hero__content">
			<h1 class="text-center md:text-left hero-title">
				<span class="h1 mt-16">Historia</span><br /><span class="text-2xl font-bold text-zinc-200 md:text-3xl"
					>de la Música</span
				>
			</h1>
			<div
				class={`artist-figure relative flex h-full items-center justify-center overflow-hidden shadow-2xl transition-shadow duration-300`}
				style={`mask-image: url(${PixelTriangle.src}); mask-size: contain; mask-repeat: no-repeat; mask-position: center; -webkit-mask-image: url(${PixelTriangle.src}); -webkit-mask-size: contain; -webkit-mask-repeat: no-repeat; -webkit-mask-position: center;`}
			>
				<Image
					src={HeroImage}
					alt="Imagen de portada"
					class="pointer-events-none h-full w-full object-contain"
					draggable="false"
				/>
			</div>
		</div>
	</section>
	<main>
		<section class="timeline-section relative py-20 overflow-hidden">
			<!-- Decorative background elements -->
			<div class="absolute top-1/4 left-0 w-64 h-64 bg-purple-900/10 rounded-full blur-3xl -z-10 pointer-events-none"></div>
			<div class="absolute bottom-1/4 right-0 w-96 h-96 bg-purple-800/10 rounded-full blur-3xl -z-10 pointer-events-none"></div>
			
			<h2 class="font-display text-center text-5xl text-zinc-100 mb-16 relative z-10">Eras Musicales</h2>
			
			<div class="timeline-container relative mx-auto max-w-6xl px-6">
				<!-- Central Line -->
				<div class="absolute left-1/2 top-4 bottom-4 w-1 bg-linear-to-b from-purple-800/20 via-purple-600/50 to-purple-800/20 -translate-x-1/2 hidden md:block z-0"></div>
				
				<div class="space-y-16">
					{eras.map((era, index) => {
						const isEven = index % 2 === 0;
						const maskSrc = eraMaskMap[era.maskKey];
						return (
							<div class={`timeline-item relative flex flex-col md:flex-row items-center justify-between gap-8 ${isEven ? '' : 'md:flex-row-reverse'}`}>
								<!-- Node Point in Center -->
								<div class="hidden md:flex absolute left-1/2 -translate-x-1/2 w-10 h-10 bg-zinc-950 rounded-full z-10 items-center justify-center border-2 border-purple-500 shadow-[0_0_15px_rgba(147,51,234,0.3)]">
									<div class="w-3 h-3 bg-purple-400 rounded-full"></div>
								</div>
								
								<!-- Content Card -->
								<a href={`/eras/${era.id}`} class={`w-full md:w-[45%] flex flex-col ${isEven ? 'items-center md:items-end text-center md:text-right' : 'items-center md:items-start text-center md:text-left'} relative z-10 group no-underline block focus:outline-none`}>
									<div class="w-full max-w-md p-8 rounded-4xl bg-zinc-900/40 backdrop-blur-md border border-zinc-800 transition-all duration-300 group-hover:-translate-y-2 group-hover:border-purple-500/50 group-hover:shadow-[0_10px_30px_-15px_rgba(147,51,234,0.3)] relative overflow-hidden flex flex-col cursor-pointer">
										
										<!-- Background Image & Grid Overlay (Visible on Hover) -->
										<div class="absolute inset-0 z-0 opacity-0 transition-opacity duration-500 group-hover:opacity-100">
											<!-- Image with transition name to animate expansion -->
											<div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 scale-100 group-hover:scale-110" style={`background-image: url('${eraImageMap[era.imageKey].src}');`} transition:name={`era-${era.id}`}></div>
											<!-- Dark Gradient to preserve text readability -->
											<div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-900/90 to-purple-900/30"></div>
											<!-- CSS Grid Pattern over image -->
											<div class="absolute inset-0 opacity-40 mix-blend-overlay" style="background-image: linear-gradient(to right, rgba(230, 230, 230, 0.15) 1px, transparent 1px), linear-gradient(to bottom, rgba(230, 230, 230, 0.15) 1px, transparent 1px); background-size: 20px 20px;"></div>
										</div>

										<!-- Inner Content -->
										<div class={`relative z-10 flex flex-col w-full h-full ${isEven ? 'items-center md:items-end' : 'items-center md:items-start'}`}>
											<div class="w-16 h-16 mb-6 bg-purple-500 transition-transform duration-500 group-hover:scale-110 group-hover:rotate-12 group-hover:bg-purple-400 group-hover:shadow-[0_0_20px_rgba(168,85,247,0.4)]" style={`mask-image: url(${maskSrc}); mask-size: contain; mask-repeat: no-repeat; mask-position: center; -webkit-mask-image: url(${maskSrc}); -webkit-mask-size: contain; -webkit-mask-repeat: no-repeat; -webkit-mask-position: center;`}></div>
											<span class="text-purple-400 font-bold tracking-widest text-xs uppercase mb-3 drop-shadow-md">{era.years}</span>
											<h3 class="font-display text-3xl text-zinc-100 mb-4 drop-shadow-lg group-hover:text-purple-300 transition-colors duration-300">{era.name}</h3>
											<p class="text-zinc-400 group-hover:text-zinc-200 transition-colors duration-300 leading-relaxed text-sm md:text-base drop-shadow-md">{era.desc}</p>
										</div>
									</div>
								</a>
								
								<!-- Empty space for the other half -->
								<div class="hidden md:block w-[45%]"></div>
							</div>
						);
					})}
				</div>
			</div>
		</section>

		<section class="instrument-section relative space-y-5 overflow-hidden rounded-4xl bg-zinc-900 px-6 py-18">
			<div
				class="cookie-deco"
				style={`mask-image: url(${ShapeCookie4.src}); -webkit-mask-image: url(${ShapeCookie4.src});`}
			>
			</div>
			<h2 class="font-display text-center text-5xl text-zinc-100">Instrumentos</h2>
			<p class="p mx-auto max-w-3xl text-center">
				Explora instrumentos que marcaron cambios técnicos, estéticos y culturales a lo largo de la historia.
			</p>
			<div class="instrument-list flex flex-wrap justify-center gap-4">
				{
					instruments.map((instrument) => (
						<Card
							title={instrument.title}
							description={instrument.year}
							maskImage={maskMap[instrument.maskKey]}
							image={instrumentImageMap[instrument.imageKey]}
							className="instrument-card"
							href={`/instruments/${instrument.id}`}
							transitionName={`instrument-${instrument.id}`}
						/>
					))
				}
			</div>
		</section>
	</main>
</Layout>

<style>
	@reference 'tailwindcss';

	.hero {
		@apply p-6;
	}
	.hero__content {
		@apply mx-auto flex max-w-7xl flex-col justify-between gap-6 rounded-4xl bg-purple-600 p-12 lg:flex-row;
		min-height: max(300px, 80vh);
		height: max(300px, 80vh);
		animation: reveal-animation 1s cubic-bezier(0.77, 0, 0.175, 1);
	}
	main {
		@apply p-6;
	}

	.instrument-section {
		view-timeline-name: --section-timeline;
	}

	/* Fallback: visibles sin animacion en navegadores sin soporte */
	.instrument-list > :global(.instrument-card) {
		opacity: 1;
	}

	@supports (animation-timeline: view()) {
		.instrument-list > :global(.instrument-card) {
			animation: pop-in ease both;
			/* Enlazamos a la visibilidad de toda la seccion en lugar de la tarjeta individual */
			animation-timeline: --section-timeline;
		}

		/* Escalonado exagerado: cada tarjeta entra con un delay de scroll mucho mayor */
		.instrument-list > :global(.instrument-card):nth-child(1) {
			animation-range: entry 20% entry 55%;
		}
		.instrument-list > :global(.instrument-card):nth-child(2) {
			animation-range: entry 35% entry 70%;
		}
		.instrument-list > :global(.instrument-card):nth-child(3) {
			animation-range: entry 50% entry 85%;
		}
		.instrument-list > :global(.instrument-card):nth-child(4) {
			animation-range: entry 65% entry 100%;
		}
		.instrument-list > :global(.instrument-card):nth-child(5) {
			animation-range: entry 80% entry 115%;
		}
	}

	.cookie-deco {
		position: absolute;
		bottom: -10%;
		right: -8%;
		width: clamp(280px, 40vw, 560px);
		aspect-ratio: 1;
		background-color: var(--color-purple-600);
		mask-size: contain;
		mask-repeat: no-repeat;
		mask-position: center;
		-webkit-mask-size: contain;
		-webkit-mask-repeat: no-repeat;
		-webkit-mask-position: center;
		opacity: 0.3;
		animation: cookie-spin 28s linear infinite;
		pointer-events: none;
	}

	@keyframes cookie-spin {
		from {
			transform: rotate(0deg);
		}
		to {
			transform: rotate(360deg);
		}
	}

	@keyframes reveal-animation {
		0% {
			clip-path: inset(100% 0 0 0);
		}
		100% {
			clip-path: inset(0 0 0 0);
		}
	}

	@keyframes pop-in {
		from {
			opacity: 0;
			transform: translateY(24px) scale(0.96);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	@supports (animation-timeline: view()) {
		.timeline-item {
			animation: timeline-fade-in ease both;
			animation-timeline: view();
			animation-range: entry 5% cover 30%;
		}
	}

	@keyframes timeline-fade-in {
		from {
			opacity: 0;
			transform: translateY(40px) scale(0.95);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	.hero-title {
		animation: reveal-animation 1s cubic-bezier(0.77, 0, 0.175, 1) 0.5s both;
	}
</style>
