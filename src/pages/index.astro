---
import Layout from '@/layouts/Layout.astro';
---

<Layout>
    <main class="w-full min-h-[calc(100vh-80px)] relative overflow-hidden bg-zinc-950 flex flex-col items-center justify-center pt-12 pb-24 px-6 md:px-12">
        
        <!-- Ambient background glows -->
        <div class="absolute top-[20%] left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-purple-600/20 blur-[130px] rounded-full pointer-events-none -z-10 mix-blend-screen"></div>
        <div class="absolute bottom-[0%] right-[10%] w-[500px] h-[500px] bg-blue-600/20 blur-[120px] rounded-full pointer-events-none -z-10 mix-blend-screen"></div>

        <section class="max-w-7xl w-full mx-auto relative z-10 text-center flex flex-col items-center">
            
            <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full border border-white/10 bg-white/5 mb-10 backdrop-blur-md opacity-0 animate-fade-in-up hover:bg-white/10 transition-colors" style="animation-delay: 0.1s;">
                <span class="w-2 h-2 rounded-full bg-purple-500 animate-pulse"></span>
                <span class="text-xs uppercase tracking-widest text-zinc-300 font-bold">El Universo del Sonido</span>
            </div>

            <h1 class="text-[5rem] sm:text-[7rem] md:text-[10rem] lg:text-[14rem] font-black font-display text-transparent bg-clip-text bg-gradient-to-b from-white to-zinc-500 leading-none tracking-normal uppercase drop-shadow-2xl opacity-0 animate-fade-in-up" style="animation-delay: 0.25s;">
                MÚSICA
            </h1>
            
            <p class="mt-8 text-xl md:text-2xl text-zinc-400 font-light max-w-2xl text-balance opacity-0 animate-fade-in-up" style="animation-delay: 0.4s;">
                Explora el catálogo definitivo de los artistas, géneros, disqueras y artefactos que moldearon la banda sonora de la humanidad.
            </p>

        </section>

        <!-- Bento Grid Navigation -->
        <section class="max-w-7xl w-full mx-auto mt-24 grid grid-cols-1 md:grid-cols-6 lg:grid-cols-12 gap-6 relative z-10 opacity-0 animate-fade-in-up" style="animation-delay: 0.55s;">
            
            <!-- Historia (Large Feature) -->
            <a href="/history" class="group relative overflow-hidden rounded-[2.5rem] bg-zinc-900/60 shadow-2xl border border-white/5 hover:border-white/20 transition-all duration-500 md:col-span-6 lg:col-span-8 h-[300px] md:h-[400px] flex flex-col justify-end p-8 md:p-12 hover:-translate-y-2 backdrop-blur-xl">
                <div class="absolute inset-0 bg-gradient-to-t from-blue-900/60 via-transparent to-transparent opacity-50 group-hover:opacity-100 transition-opacity duration-700 mix-blend-screen"></div>
                <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-blue-500/10 blur-[80px] rounded-full mix-blend-screen pointer-events-none group-hover:bg-blue-500/30 transition-colors duration-700"></div>
                <div class="relative z-10">
                    <span class="text-sm font-bold tracking-widest uppercase text-blue-400 mb-3 block group-hover:-translate-y-1 transition-transform duration-500">Línea de Tiempo</span>
                    <h2 class="text-4xl md:text-6xl font-black font-display text-white uppercase tracking-normal group-hover:drop-shadow-[0_0_20px_rgba(255,255,255,0.3)] transition-all duration-500">Historia</h2>
                    <p class="mt-4 text-zinc-400 font-light line-clamp-2 max-w-lg">Un viaje a través de las eras musicales que revolucionaron nuestra forma de escuchar el mundo.</p>
                </div>
            </a>

            <!-- Artistas (Tall block) -->
            <a href="/artists" class="group relative overflow-hidden rounded-[2.5rem] bg-zinc-900/60 shadow-2xl border border-white/5 hover:border-white/20 transition-all duration-500 md:col-span-6 lg:col-span-4 h-[300px] md:h-[400px] flex flex-col justify-end p-8 md:p-12 hover:-translate-y-2 backdrop-blur-xl">
                <div class="absolute inset-0 bg-gradient-to-t from-purple-900/60 via-transparent to-transparent opacity-50 group-hover:opacity-100 transition-opacity duration-700 mix-blend-screen"></div>
                <div class="absolute -top-10 -right-10 w-[300px] h-[300px] bg-purple-500/10 blur-[80px] rounded-full mix-blend-screen pointer-events-none group-hover:bg-purple-500/30 transition-colors duration-700"></div>
                <div class="relative z-10">
                    <span class="text-sm font-bold tracking-widest uppercase text-purple-400 mb-3 block group-hover:-translate-y-1 transition-transform duration-500">Voces e Íconos</span>
                    <h2 class="text-4xl md:text-6xl font-black font-display text-white uppercase tracking-normal group-hover:drop-shadow-[0_0_20px_rgba(255,255,255,0.3)] transition-all duration-500">Artistas</h2>
                </div>
            </a>

            <!-- Géneros -->
            <a href="/genres" class="group relative overflow-hidden rounded-[2.5rem] bg-zinc-900/60 shadow-2xl border border-white/5 hover:border-white/20 transition-all duration-500 md:col-span-4 h-[250px] flex flex-col justify-end p-8 hover:-translate-y-2 backdrop-blur-xl">
                <div class="absolute inset-0 bg-gradient-to-t from-emerald-900/50 via-transparent to-transparent opacity-40 group-hover:opacity-100 transition-opacity duration-700 mix-blend-screen"></div>
                <div class="relative z-10">
                    <span class="text-xs font-bold tracking-widest uppercase text-emerald-400 mb-2 block group-hover:-translate-y-1 transition-transform duration-500">Sonoridades</span>
                    <h2 class="text-4xl font-black font-display text-white uppercase tracking-normal group-hover:drop-shadow-[0_0_20px_rgba(255,255,255,0.3)] transition-all duration-500">Géneros</h2>
                </div>
            </a>

            <!-- Instrumentos -->
            <a href="/instruments" class="group relative overflow-hidden rounded-[2.5rem] bg-zinc-900/60 shadow-2xl border border-white/5 hover:border-white/20 transition-all duration-500 md:col-span-4 h-[250px] flex flex-col justify-end p-8 hover:-translate-y-2 backdrop-blur-xl">
                <div class="absolute inset-0 bg-gradient-to-t from-orange-900/50 via-transparent to-transparent opacity-40 group-hover:opacity-100 transition-opacity duration-700 mix-blend-screen"></div>
                <div class="relative z-10">
                    <span class="text-xs font-bold tracking-widest uppercase text-orange-400 mb-2 block group-hover:-translate-y-1 transition-transform duration-500">Herramientas</span>
                    <h2 class="text-4xl font-black font-display text-white uppercase tracking-normal group-hover:drop-shadow-[0_0_20px_rgba(255,255,255,0.3)] transition-all duration-500">Instrumentos</h2>
                </div>
            </a>

            <!-- Disqueras -->
            <a href="/labels" class="group relative overflow-hidden rounded-[2.5rem] bg-zinc-900/60 shadow-2xl border border-white/5 hover:border-white/20 transition-all duration-500 md:col-span-4 h-[250px] flex flex-col justify-end p-8 hover:-translate-y-2 backdrop-blur-xl">
                <div class="absolute inset-0 bg-gradient-to-t from-red-900/50 via-transparent to-transparent opacity-40 group-hover:opacity-100 transition-opacity duration-700 mix-blend-screen"></div>
                <div class="relative z-10">
                    <span class="text-xs font-bold tracking-widest uppercase text-red-500 mb-2 block group-hover:-translate-y-1 transition-transform duration-500">Catálogos</span>
                    <h2 class="text-4xl font-black font-display text-white uppercase tracking-normal group-hover:drop-shadow-[0_0_20px_rgba(255,255,255,0.3)] transition-all duration-500">Disqueras</h2>
                </div>
            </a>

        </section>
        
    </main>
</Layout>

<style>
    @reference "../global.css";

    @keyframes fade-in-up {
        0% {
            opacity: 0;
            transform: translateY(40px) scale(0.98);
            filter: blur(10px);
        }
        100% {
            opacity: 1;
            transform: translateY(0) scale(1);
            filter: blur(0);
        }
    }

    .animate-fade-in-up {
        animation: fade-in-up 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
</style>
