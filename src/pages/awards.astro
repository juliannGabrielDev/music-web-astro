---

<Layout title="Premios | Música">
  <!-- ─── HERO ─────────────────────────────────────────────── -->
  <section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden px-6 py-24">
    <!-- Atmospheric glows -->
    <div class="absolute top-1/4 left-1/3 w-[700px] h-[700px] bg-amber-500/15 blur-[150px] rounded-full pointer-events-none mix-blend-screen -z-10"></div>
    <div class="absolute bottom-1/4 right-1/3 w-[500px] h-[500px] bg-yellow-600/10 blur-[130px] rounded-full pointer-events-none mix-blend-screen -z-10"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[400px] bg-amber-600/8 blur-[120px] rounded-full pointer-events-none mix-blend-screen -z-10"></div>

    <!-- Grid dot overlay -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_at_center,black_40%,transparent_70%)] -z-10"></div>

    <!-- Vertical hairlines -->
    <div class="absolute left-1/4 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-white to-transparent opacity-[0.07] -z-10"></div>
    <div class="absolute left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-white to-transparent opacity-[0.07] -z-10"></div>
    <div class="absolute left-3/4 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-white to-transparent opacity-[0.07] -z-10"></div>

    <!-- Large decorative star -->
    <div class="absolute top-12 right-12 text-[20rem] font-black text-amber-400/[0.03] pointer-events-none select-none leading-none -z-10">★</div>

    <!-- Eyebrow -->
    <div class="hero-eyebrow mb-6 z-10">
      <div class="flex items-center gap-4">
        <div class="h-px w-16 bg-gradient-to-r from-transparent to-amber-400"></div>
        <span class="text-xs font-bold tracking-widest uppercase text-amber-400">Reconocimientos & Legado</span>
        <div class="h-px w-16 bg-gradient-to-l from-transparent to-amber-400"></div>
      </div>
    </div>

    <!-- Main title -->
    <div class="hero-title z-10 text-center">
      <h1 class="font-display font-black uppercase leading-none text-7xl md:text-[10rem] lg:text-[13rem] text-transparent bg-clip-text bg-gradient-to-b from-amber-200 via-zinc-100 to-zinc-500 tracking-tight">
        AWARDS
      </h1>
    </div>

    <!-- Subtitle -->
    <p class="hero-subtitle z-10 mt-6 text-center text-xl text-zinc-400 font-light max-w-xl leading-relaxed">
      Los galardones que definieron eras, consagraron artistas y escribieron la historia de la música.
    </p>

    <!-- Stats strip -->
    <div class="hero-stats z-10 mt-16 grid grid-cols-2 md:grid-cols-4 gap-4 w-full max-w-4xl">
      <div class="stat-card p-5 rounded-2xl bg-zinc-900/40 border border-white/5 backdrop-blur-md text-center">
        <span class="block text-3xl font-black font-display text-amber-300">32</span>
        <span class="block text-xs font-bold tracking-widest uppercase text-zinc-500 mt-1">Récord de Grammys</span>
        <span class="block text-xs text-zinc-600 mt-0.5">Beyoncé</span>
      </div>
      <div class="stat-card p-5 rounded-2xl bg-zinc-900/40 border border-white/5 backdrop-blur-md text-center">
        <span class="block text-3xl font-black font-display text-amber-300">66</span>
        <span class="block text-xs font-bold tracking-widest uppercase text-zinc-500 mt-1">Años de historia</span>
        <span class="block text-xs text-zinc-600 mt-0.5">Grammy Awards</span>
      </div>
      <div class="stat-card p-5 rounded-2xl bg-zinc-900/40 border border-white/5 backdrop-blur-md text-center">
        <span class="block text-3xl font-black font-display text-amber-300">900+</span>
        <span class="block text-xs font-bold tracking-widest uppercase text-zinc-500 mt-1">Hall of Fame</span>
        <span class="block text-xs text-zinc-600 mt-0.5">Inductees</span>
      </div>
      <div class="stat-card p-5 rounded-2xl bg-zinc-900/40 border border-white/5 backdrop-blur-md text-center">
        <span class="block text-3xl font-black font-display text-amber-300">∞</span>
        <span class="block text-xs font-bold tracking-widest uppercase text-zinc-500 mt-1">Legado musical</span>
        <span class="block text-xs text-zinc-600 mt-0.5">Para siempre</span>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40">
      <span class="text-xs font-bold tracking-widest uppercase text-zinc-500">Scroll</span>
      <div class="w-px h-12 bg-gradient-to-b from-zinc-500 to-transparent"></div>
    </div>
  </section>

  <!-- ─── MARQUEE ───────────────────────────────────────────── -->
  <div class="relative w-screen left-1/2 right-1/2 -mx-[50vw] overflow-hidden py-8 bg-zinc-900/80 border-y border-white/5">
    <div class="flex items-center marquee-wrapper">
      <div class="flex gap-12 items-center shrink-0 marquee-content">
        {marqueeItems.map((name) => (
          <span class="flex items-center gap-10 text-5xl font-black font-display uppercase text-zinc-800 whitespace-nowrap">
            {name}
            <span class="text-amber-500/30 text-2xl select-none">★</span>
          </span>
        ))}
      </div>
      <div class="flex gap-12 items-center shrink-0 marquee-content" aria-hidden="true">
        {marqueeItems.map((name) => (
          <span class="flex items-center gap-10 text-5xl font-black font-display uppercase text-zinc-800 whitespace-nowrap">
            {name}
            <span class="text-amber-500/30 text-2xl select-none">★</span>
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- ─── RECORD HOLDERS BENTO ──────────────────────────────── -->
  <section class="relative px-6 py-32 max-w-[1400px] mx-auto">
    <div class="absolute top-1/3 right-0 w-[500px] h-[500px] bg-amber-600/8 blur-[130px] rounded-full pointer-events-none mix-blend-screen -z-10"></div>

    <div class="mb-16 slide-up-content">
      <span class="text-xs font-bold tracking-widest uppercase text-amber-400 mb-3 block">Récords Históricos</span>
      <h2 class="font-display font-black uppercase text-6xl md:text-8xl text-zinc-100 leading-none">
        LOS MÁS<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-amber-600">PREMIADOS</span>
      </h2>
    </div>

    <!-- Bento: 1 large + 4 smaller cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-4">

      <!-- Beyoncé — featured large -->
      <div class="lg:col-span-7 group relative rounded-[2.5rem] bg-zinc-900/60 border border-white/5 hover:border-amber-500/30 overflow-hidden transition-all duration-500 hover:-translate-y-2 p-8 md:p-12 min-h-[400px] flex flex-col md:flex-row gap-8 slide-up-content">
        <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-amber-500/10 blur-[100px] rounded-full opacity-50 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
        <div class="absolute -bottom-6 -right-4 text-[14rem] font-black text-amber-400/[0.04] pointer-events-none select-none leading-none font-display">★</div>

        <!-- Text content -->
        <div class="flex-1 flex flex-col justify-between relative z-10">
          <div>
            <div class="flex items-start justify-between mb-6">
              <span class="px-3 py-1 rounded-full bg-amber-500/10 text-amber-300 text-xs font-bold tracking-widest uppercase border border-amber-500/20">#1 · Récord Mundial</span>
              <span class="text-xs font-mono text-zinc-600">01 / 05</span>
            </div>
            <div class="flex items-end gap-4 mb-4">
              <span class="font-display font-black text-[6rem] leading-none text-transparent bg-clip-text bg-gradient-to-b from-amber-200 to-amber-500">32</span>
              <div class="mb-4">
                <span class="block text-sm font-bold tracking-widest uppercase text-zinc-500">Premios Grammy</span>
                <span class="block text-xs text-zinc-600 mt-0.5">Más que cualquier artista en la historia</span>
              </div>
            </div>
            <h3 class="font-display font-black uppercase text-4xl text-zinc-100 group-hover:text-amber-200 transition-colors duration-500">Beyoncé</h3>
            <p class="text-zinc-400 mt-3 font-light leading-relaxed">
              Con 32 premios Grammy, Beyoncé es la artista más galardonada en la historia. Sus victorias abarcan R&B, pop, country y hip-hop, consolidando un legado sin precedentes.
            </p>
          </div>
          <div class="flex flex-wrap gap-2 mt-6">
            {recordHolders[0].genres.map((g) => (
              <span class="px-3 py-1 rounded-full bg-white/5 text-zinc-300 text-xs font-bold tracking-wide uppercase border border-white/10">{g}</span>
            ))}
          </div>
        </div>

        <!-- Photo -->
        <div class="shrink-0 self-center w-55 h-65 md:w-65 md:h-80 relative z-10"
          style={`mask-image: url(${shapeCookie12.src}); mask-size: contain; mask-repeat: no-repeat; mask-position: center; -webkit-mask-image: url(${shapeCookie12.src}); -webkit-mask-size: contain; -webkit-mask-repeat: no-repeat; -webkit-mask-position: center;`}>
          <Image
            src={beyonceImg}
            alt="Beyoncé"
            class="w-full h-full object-cover object-top filter saturate-[0.8] contrast-[1.05] group-hover:saturate-100 transition-all duration-1000"
          />
        </div>
      </div>

      <!-- Right column: 4 smaller cards -->
      <div class="lg:col-span-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
        {recordHolders.slice(1).map((holder) => (
          <div class={`group relative rounded-[2rem] bg-zinc-900/60 border border-white/5 overflow-hidden transition-all duration-500 hover:-translate-y-2 p-7 flex flex-col gap-4 slide-up-content holder-card-${holder.color}`}>
            <div class={`absolute top-0 right-0 w-[200px] h-[200px] blur-[80px] rounded-full opacity-40 group-hover:opacity-80 transition-opacity duration-700 pointer-events-none holder-glow-${holder.color}`}></div>

            <!-- Photo + rank row -->
            <div class="flex items-start justify-between relative z-10">
              <span class={`px-2.5 py-1 rounded-full text-xs font-bold tracking-widest uppercase border holder-badge-${holder.color}`}>
                {holder.genres[0]}
              </span>
              <div class="w-16 h-16 shrink-0"
                style={`mask-image: url(${holder.shape.src}); mask-size: contain; mask-repeat: no-repeat; mask-position: center; -webkit-mask-image: url(${holder.shape.src}); -webkit-mask-size: contain; -webkit-mask-repeat: no-repeat; -webkit-mask-position: center;`}>
                <Image
                  src={holder.image}
                  alt={holder.name}
                  class="w-full h-full object-cover object-top filter saturate-75 group-hover:saturate-100 transition-all duration-700"
                />
              </div>
            </div>

            <div class="relative z-10">
              <div class="flex items-end gap-2 mb-1.5">
                <span class={`font-display font-black text-[3.5rem] leading-none holder-count-${holder.color}`}>{holder.count}</span>
                <span class="text-xs font-bold tracking-widest uppercase text-zinc-600 mb-3">Grammy</span>
              </div>
              <h3 class={`font-display font-black uppercase text-xl text-zinc-100 transition-colors duration-500 holder-name-${holder.color}`}>
                {holder.name}
              </h3>
              <p class="text-zinc-600 mt-1 text-xs leading-relaxed">{holder.note}</p>
            </div>
