    color: 'cyan',
    image: bowieSpeechImg,
  },
];

const hallOfFameDecades = [
  {
    decade: '1950s',
    label: 'Los Pioneros',
    acts: ['Chuck Berry', 'Little Richard', 'Elvis Presley', 'Buddy Holly', 'Ray Charles', 'Fats Domino'],
    color: 'amber',
  },
  {
    decade: '1970s',
