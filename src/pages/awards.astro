    description: 'Chuck Berry, Elvis Presley, Little Richard y Ray Charles son los primeros inductos del Rock and Roll Hall of Fame.',
    category: 'Hall of Fame',
    color: 'orange',
    image: rockHallMoment,
  },
  {
    year: '2003',
    event: 'Beyoncé emerge',
    description: 'Gana su primer Grammy por "Crazy in Love". Iniciaría su camino hacia ser la artista más premiada de la historia.',
