---
import { Image } from 'astro:assets';
import Layout from '@/layouts/Layout.astro';

// Import all requested organic shapes
import shapeCookie4 from '@/assets/figures/sided-cookie-4.svg';
import shapeSoftBoom from '@/assets/figures/soft-boom.svg';
import shapeFlower from '@/assets/figures/flower.svg';
import shapeGum from '@/assets/figures/Gum.svg';
import shapeGhost from '@/assets/figures/ghost-ish.svg';
import shapePill from '@/assets/figures/pill.svg';
import shapeCircle from '@/assets/figures/Circle.svg';
import shapeSquare from '@/assets/figures/Square.svg';
import shapeArrow from '@/assets/figures/arrow.svg';
import shapePixelCircle from '@/assets/figures/pixel-circle.svg';
import shapePuffyDiamond from '@/assets/figures/puffy-diamond.svg';
import shapeCookie12 from '@/assets/figures/sided-cookie-12.svg';
import shapeTriangle from '@/assets/figures/triangle.svg';

import Adele from '@/assets/artists/adele.webp';
import AmyWinehouse from '@/assets/artists/amy-winehouse.webp';
import CarlyRaeJepsen from '@/assets/artists/carly-rae-jepsen.webp';
import LadyGaga from '@/assets/artists/lady-gaga.webp';
import LanaDelRey from '@/assets/artists/lana-del-rey.webp';
import MeghanTrainor from '@/assets/artists/meghan-trainor.webp';
import Raye from '@/assets/artists/raye.webp';
import Top from '@/assets/artists/top.webp';
import Twice from '@/assets/artists/twice.webp';
import OliviaDean from '@/assets/artists/olivia-dean.webp';
import ColdPlay from '@/assets/artists/cold-play.webp';
import Pink from '@/assets/artists/pink.webp';
import RobbieWilliams from '@/assets/artists/robbie-williams.webp';
import SpiceGirls from '@/assets/artists/spice-girls.webp';
import BritneySpears from '@/assets/artists/britney-spears.webp';
import Aurora from '@/assets/artists/aurora.webp';
import ConanGray from '@/assets/artists/conan-gray.webp';
import KatyPerry from '@/assets/artists/katy-perry.webp';

import AdeleArtist from '@/assets/artists/adele-artist.webp';
import topArtist from '@/assets/artists/twenty-one-pilots-artist.webp';
import lanaArtist from '@/assets/artists/lana-del-rey-artist.webp';
import rayeArtist from '@/assets/artists/raye-artist.webp';
import katyArtist from '@/assets/artists/katy-perry-artist.webp';
import AmyArtist from '@/assets/artists/amy-winehouse-artist.webp';

const baseSlides = [
	{
		type: 'single',
		shape: shapeCookie12.src,
		img: Adele,
	},
	{
		type: 'single',
		shape: shapePixelCircle.src,
		img: Top,
	},
	{
		type: 'quad',
		items: [
			{
				img: Raye,
				shape: shapeCookie4.src,
			},
			{
				img: AmyWinehouse,
				shape: shapeSoftBoom.src,
			},
			{
				img: CarlyRaeJepsen,
				shape: shapeFlower.src,
			},
			{
				img: LadyGaga,
				shape: shapeGum.src,
			},
		],
	},
	{
		type: 'single',
		shape: shapeGhost.src,
		img: LanaDelRey,
	},
	{
		type: 'quad',
		items: [
			{
				img: SpiceGirls,
				shape: shapeGhost.src,
			},
			{
				img: RobbieWilliams,
				shape: shapePill.src,
			},
			{
				img: Pink,
				shape: shapeCircle.src,
			},
			{
				img: ColdPlay,
				shape: shapeSquare.src,
			},
		],
	},
	{
		type: 'single',
		shape: shapeFlower.src,
		img: OliviaDean,
	},
	{
		type: 'single',
		shape: shapeArrow.src,
		img: MeghanTrainor,
	},
	{
		type: 'quad',
		items: [
			{
				img: KatyPerry,
				shape: shapePixelCircle.src,
			},
			{
				img: BritneySpears,
				shape: shapePuffyDiamond.src,
			},
			{
				img: Aurora,
				shape: shapeCookie12.src,
			},
			{
				img: ConanGray,
				shape: shapeTriangle.src,
			},
		],
	},
	{
		type: 'single',
		shape: shapePill.src,
		img: Twice,
	},
];

const slides = [...baseSlides, ...baseSlides];
---

<Layout>
	<section class="hero relative pt-32 pb-20 overflow-clip">
		<!-- Ambient glows -->
		<div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-[500px] bg-purple-600/20 blur-[120px] rounded-full pointer-events-none -z-10"></div>
		
		<div class="text-center mb-16 relative z-10 w-full px-6">
			<h1 class="hero-title text-transparent bg-clip-text bg-gradient-to-b from-white via-white to-white/40 tracking-[0em] text-7xl md:text-8xl lg:text-[10rem] font-display font-black drop-shadow-2xl uppercase leading-none mx-auto">
				Artistas
			</h1>
		</div>

		<ul class="carousel relative z-10">
			{
				slides.map((slide, index) => (
					<li class="carousel__item">
						{slide.type === 'single' ? (
							<div
								class={`artist-figure relative flex h-full w-full items-center justify-center overflow-hidden shadow-2xl transition-shadow duration-300`}
								style={`mask-image: url(${slide.shape}); mask-size: contain; mask-repeat: no-repeat; mask-position: center; -webkit-mask-image: url(${slide.shape}); -webkit-mask-size: contain; -webkit-mask-repeat: no-repeat; -webkit-mask-position: center;`}
							>
								<Image
									src={slide.img}
									alt={`Artist ${index + 1}`}
									class="pointer-events-none h-full w-full object-cover"
									draggable="false"
								/>
							</div>
						) : (
							<div class="grid h-full w-full grid-cols-2 grid-rows-2 gap-2 p-1 md:gap-4">
								{slide.items!.map((subItem) => (
									<div
										class="artist-figure relative h-full w-full overflow-hidden shadow-lg"
										style={`mask-image: url(${subItem.shape}); mask-size: contain; mask-repeat: no-repeat; mask-position: center; -webkit-mask-image: url(${subItem.shape}); -webkit-mask-size: contain; -webkit-mask-repeat: no-repeat; -webkit-mask-position: center;`}
									>
										<Image
											src={subItem.img}
											alt={`Artist from group ${index + 1}`}
											class="pointer-events-none h-full w-full object-cover"
											draggable="false"
										/>
									</div>
								))}
							</div>
						)}
					</li>
				))
			}
		</ul>
		<div class="mx-auto mt-20 flex w-full max-w-4xl flex-col items-center px-6 relative z-10">
			<div class="flex items-center gap-4 opacity-60">
				<div class="h-[1px] w-12 sm:w-24 bg-gradient-to-r from-transparent to-zinc-400"></div>
				<span class="text-xs font-bold tracking-[0.3em] uppercase text-zinc-300">Desliza</span>
				<div class="h-[1px] w-12 sm:w-24 bg-gradient-to-l from-transparent to-zinc-400"></div>
			</div>
			<p class="mt-6 max-w-md text-center text-lg leading-relaxed font-light text-zinc-400">
				Una selección curada de voces y talentos que han definido mis gustos musicales.
			</p>
		</div>
	</section>
	<div class="container">
		<main class="w-full flex-1 space-y-32 lg:pb-32">
			<!-- Adele: Horizontal Split Feature -->
			<article id="adele" class="relative grid grid-cols-1 lg:grid-cols-12 gap-8 items-center group">
				<div class="lg:col-span-5 space-y-6 relative z-10 p-6 lg:p-10 rounded-[3rem] bg-zinc-900 border border-zinc-800 shadow-2xl backdrop-blur-xl transition-all duration-500 hover:border-purple-500/30 slide-up-content">
					<div class="absolute -top-12 -left-8 text-[8rem] font-black text-white/5 pointer-events-none select-none tracking-tighter leading-none z-0 parallax-number">01</div>
					<h2 class="h2 relative z-10 text-5xl md:text-6xl text-white group-hover:text-purple-300 transition-colors duration-300">ADELE</h2>
					<p class="p relative z-10 text-zinc-400 leading-relaxed font-light">
						Adele Laurie Blue Adkins, conocida simplemente como Adele, es una cantautora y multinstrumentista británica.
						Es una de las artistas musicales con mayores ventas del mundo, con más de 120 millones de ventas entre discos
						y sencillos. En 2008, lanzó su álbum de estudio debut, 19, el cual se situó en la posición 1 de la lista de
						álbumes británica.
					</p>
					<div class="flex items-center gap-3 pt-4 border-t border-zinc-800/50">
						<span class="px-4 py-1.5 rounded-full bg-purple-500/10 text-purple-300 text-xs font-bold tracking-widest uppercase border border-purple-500/20">Soul</span>
						<span class="px-4 py-1.5 rounded-full bg-white/5 text-zinc-300 text-xs font-bold tracking-widest uppercase border border-white/10">Pop</span>
					</div>
				</div>
				<div class="lg:col-span-7 relative h-[400px] lg:h-[600px] w-full rounded-[2.5rem] overflow-clip order-first lg:order-none">
					<div class="absolute inset-0 bg-purple-900/20 mix-blend-multiply z-10 group-hover:opacity-0 transition-opacity duration-700"></div>
					<Image src={AdeleArtist} alt="Adele en los Grammys de 2012" class="w-full h-full object-cover article__image scale-100 group-hover:scale-105 transition-transform duration-1000 ease-out" />
					<!-- Decoration -->
					<div class="absolute -bottom-10 -right-10 w-40 h-40 bg-purple-500/20 blur-2xl rounded-full mix-blend-screen z-20 pointer-events-none"></div>
				</div>
			</article>

			<!-- Twenty One Pilots: Bento Box Grid -->
			<article id="top" class="relative group">
				<div class="absolute -top-20 -right-10 text-[10rem] font-black text-white/5 pointer-events-none select-none tracking-tighter leading-none z-0 parallax-number">02</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-4 lg:gap-6 relative z-10">
					<!-- Main Image Focus -->
					<div class="md:col-span-2 h-[300px] md:h-[500px] rounded-[2.5rem] overflow-clip relative">
						<div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-transparent to-transparent z-10 opacity-60"></div>
						<Image src={topArtist} alt="Twenty One Pilots en Breach" class="w-full h-full object-cover article__image scale-100 group-hover:scale-105 transition-transform duration-1000 ease-out" />
						<div class="absolute bottom-6 left-8 z-20">
							<h2 class="h2 text-6xl md:text-7xl text-white group-hover:text-yellow-400 transition-colors duration-300 drop-shadow-lg">TWENTY ONE PILOTS</h2>
						</div>
					</div>
					<!-- Content Block -->
					<div class="md:col-span-1 p-8 lg:p-10 rounded-[2.5rem] bg-zinc-900 border border-zinc-800 flex flex-col justify-center space-y-6 transition-all duration-500 hover:border-yellow-400/30 slide-up-content">
						<p class="p text-zinc-400 font-light leading-relaxed">
							Dúo musical estadounidense de Columbus, Ohio. La formación consiste en el cantante Tyler Joseph y el baterista Josh Dun. El grupo es principalmente conocido por los sencillos "Stressed Out", "Ride" y "Heathens". El grupo recibió un Premio Grammy.
						</p>
						<div class="flex flex-wrap gap-2 pt-6">
							<span class="px-4 py-1.5 rounded-full bg-yellow-500/10 text-yellow-500 text-xs font-bold tracking-widest uppercase border border-yellow-500/20">Alt Rock</span>
							<span class="px-4 py-1.5 rounded-full bg-white/5 text-zinc-300 text-xs font-bold tracking-widest uppercase border border-white/10">Indie Pop</span>
						</div>
					</div>
				</div>
			</article>

			<!-- Lana Del Rey: Vertical elegant -->
			<article id="lana-del-rey" class="relative flex flex-col lg:flex-row items-center gap-12 group">
				<div class="w-full lg:w-1/2 relative h-[500px] lg:h-[700px] rounded-full overflow-clip shadow-2xl ring-1 ring-white/10 ring-offset-8 ring-offset-zinc-950">
					<div class="absolute inset-0 bg-orange-900/20 mix-blend-color-burn z-10 group-hover:opacity-0 transition-opacity duration-700"></div>
					<Image src={lanaArtist} alt="Lana Del Rey en Born To Die" class="w-full h-full object-cover article__image scale-100 group-hover:scale-105 transition-transform duration-1000 ease-out" />
				</div>
				<div class="w-full lg:w-1/2 space-y-8 lg:pl-12 relative z-10 slide-up-content">
					<div class="absolute -top-10 left-0 text-[12rem] font-black text-white/5 pointer-events-none select-none tracking-tighter leading-none z-0 parallax-number">03</div>
					<h2 class="h2 text-6xl md:text-[5rem] leading-[0.9] text-white group-hover:text-orange-200 transition-colors duration-300">LANA<br/><span class="text-zinc-500">DEL REY</span></h2>
					<div class="w-12 h-1 bg-gradient-to-r from-orange-300 to-transparent"></div>
					<p class="p text-xl text-zinc-300 leading-relaxed font-serif italic">
						"Elizabeth Woolridge Grant, su música se distingue por su calidad cinematográfica, su estilo retro y su exploración del romance trágico, el glamur y la melancolía."
					</p>
					<p class="p text-zinc-400 font-light">
						Con frecuentes referencias a la cultura pop contemporánea y a la época dorada de los años 1950 y 1960 en Estados Unidos. Es una cantante, compositora, modelo, actriz, escritora y poetisa.
					</p>
				</div>
			</article>

			<!-- Raye: Collage Block -->
			<article id="raye" class="relative group mt-24">
				<div class="absolute -top-16 left-1/2 -translate-x-1/2 text-[8rem] md:text-[15rem] font-black text-white/5 pointer-events-none select-none tracking-tighter leading-none z-0 parallax-number">04</div>
				<div class="grid grid-cols-1 md:grid-cols-12 gap-6 relative z-10">
					<div class="md:col-span-5 flex flex-col justify-end space-y-6 p-8 rounded-[3rem] bg-zinc-900 border border-zinc-800 transition-all duration-500 hover:border-red-500/30 slide-up-content">
						<h2 class="h2 text-7xl text-white group-hover:text-red-400 transition-colors duration-300">RAYE</h2>
						<p class="p text-zinc-400 font-light leading-relaxed">
							Rachel Agatha Keen es una cantante y compositora británica. Alcanzó la fama tras la publicación en 2016 de una canción de Jonas Blue, «By Your Side», en la que participó como vocalista y saltó a la popularidad global.
						</p>
						<div class="flex flex-wrap gap-2 pt-2">
							<span class="px-4 py-1.5 rounded-full bg-red-500/10 text-red-400 text-xs font-bold tracking-widest uppercase border border-red-500/20">R&B</span>
							<span class="px-4 py-1.5 rounded-full bg-white/5 text-zinc-300 text-xs font-bold tracking-widest uppercase border border-white/10">Soul</span>
						</div>
					</div>
					<div class="md:col-span-7 h-[400px] md:h-[500px] rounded-[3rem] overflow-clip relative bg-zinc-800">
						<div class="absolute inset-0 bg-gradient-to-tr from-red-900/30 to-transparent z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
						<Image src={rayeArtist} alt="Retrato de Raye" class="w-full h-full object-cover article__image object-top scale-100 group-hover:scale-105 transition-transform duration-1000 ease-out" />
					</div>
				</div>
			</article>

			<!-- Katy Perry & Amy: Split Screen -->
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 mt-32">
				<article id="katy-perry" class="relative group space-y-6">
					<div class="absolute -top-12 -left-6 text-[8rem] font-black text-white/5 pointer-events-none select-none tracking-tighter leading-none z-0 parallax-number">05</div>
					<div class="h-[400px] rounded-[3rem] overflow-clip relative">
						<Image src={katyArtist} alt="Katy Perry" class="w-full h-full object-cover article__image scale-100 group-hover:scale-105 transition-transform duration-1000 ease-out" />
					</div>
					<h2 class="h2 text-5xl text-white group-hover:text-pink-400 transition-colors duration-300 relative z-10 slide-up-content">KATY PERRY</h2>
					<p class="p text-zinc-400 font-light relative z-10 slide-up-content">
						Es una de las artistas musicales con mayores ventas, con más de 151 millones de unidades vendidas en todo el mundo. Ha dejado una enorme influencia en la música pop gracias a su estilo camp y estética ultra-colorida.
					</p>
					<div class="flex gap-2 relative z-10 slide-up-content">
						<span class="px-4 py-1.5 rounded-full bg-pink-500/10 text-pink-400 text-xs font-bold tracking-widest uppercase border border-pink-500/20">Pop</span>
					</div>
				</article>

				<article id="amy-winehouse" class="relative group space-y-6 pt-12 lg:pt-24 lg:-mt-24">
					<div class="absolute -top-0 -left-6 text-[8rem] font-black text-white/5 pointer-events-none select-none tracking-tighter leading-none z-0 parallax-number">06</div>
					<div class="h-[400px] rounded-[3rem] overflow-clip relative">
						<div class="absolute inset-0 bg-stone-900/30 mix-blend-multiply z-10 group-hover:opacity-0 transition-opacity duration-500"></div>
						<Image src={AmyArtist} alt="Amy Winehouse" class="w-full h-full object-cover article__image scale-100 group-hover:scale-105 transition-transform duration-1000 ease-out grayscale hover:grayscale-0" />
					</div>
					<h2 class="h2 text-5xl text-white group-hover:text-stone-300 transition-colors duration-300 relative z-10 slide-up-content">AMY WINEHOUSE</h2>
					<p class="p text-zinc-400 font-light relative z-10 slide-up-content">
						Conocida por su poderosa y profunda voz de contralto y su ecléctica mezcla de géneros musicales, que incluyen soul, jazz, R&B y ritmos caribeños como el ska. Debutó con el elogiado álbum Frank.
					</p>
					<div class="flex gap-2 relative z-10 slide-up-content">
						<span class="px-4 py-1.5 rounded-full bg-stone-500/10 text-stone-300 text-xs font-bold tracking-widest uppercase border border-stone-500/20">Jazz / Soul</span>
					</div>
				</article>
			</div>
		</main>
		<aside class="toc-container order-1 lg:order-2 w-full lg:w-[320px] xl:w-[380px] shrink-0">
			<nav class="toc" aria-label="Índice de artistas">
				<div class="flex items-center gap-3 mb-8 px-2">
					<div class="w-2 h-2 rounded-full bg-purple-500 animate-pulse"></div>
					<h3 class="text-xs font-bold tracking-[0.2em] text-zinc-400 uppercase">Directorio</h3>
				</div>
				<ul>
					<li>
						<a href="#adele" class="group">
							<div class="flex items-center gap-4">
								<span class="text-xs font-mono text-zinc-500 transition-colors group-hover:text-purple-400">01</span>
								<span class="font-display tracking-widest text-lg text-zinc-300 transition-colors group-hover:text-white">ADELE</span>
							</div>
							<svg class="w-4 h-4 text-zinc-500 opacity-0 -translate-x-2 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0 group-hover:text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</a>
					</li>
					<li>
						<a href="#top" class="group">
							<div class="flex items-center gap-4">
								<span class="text-xs font-mono text-zinc-500 transition-colors group-hover:text-yellow-400">02</span>
								<span class="font-display tracking-widest text-lg text-zinc-300 transition-colors group-hover:text-white">TWENTY ONE PILOTS</span>
							</div>
							<svg class="w-4 h-4 text-zinc-500 opacity-0 -translate-x-2 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0 group-hover:text-yellow-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</a>
					</li>
					<li>
						<a href="#lana-del-rey" class="group">
							<div class="flex items-center gap-4">
								<span class="text-xs font-mono text-zinc-500 transition-colors group-hover:text-orange-300">03</span>
								<span class="font-display tracking-widest text-lg text-zinc-300 transition-colors group-hover:text-white">LANA DEL REY</span>
							</div>
							<svg class="w-4 h-4 text-zinc-500 opacity-0 -translate-x-2 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0 group-hover:text-orange-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</a>
					</li>
					<li>
						<a href="#raye" class="group">
							<div class="flex items-center gap-4">
								<span class="text-xs font-mono text-zinc-500 transition-colors group-hover:text-red-400">04</span>
								<span class="font-display tracking-widest text-lg text-zinc-300 transition-colors group-hover:text-white">RAYE</span>
							</div>
							<svg class="w-4 h-4 text-zinc-500 opacity-0 -translate-x-2 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0 group-hover:text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</a>
					</li>
					<li>
						<a href="#katy-perry" class="group">
							<div class="flex items-center gap-4">
								<span class="text-xs font-mono text-zinc-500 transition-colors group-hover:text-pink-400">05</span>
								<span class="font-display tracking-widest text-lg text-zinc-300 transition-colors group-hover:text-white">KATY PERRY</span>
							</div>
							<svg class="w-4 h-4 text-zinc-500 opacity-0 -translate-x-2 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0 group-hover:text-pink-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</a>
					</li>
					<li>
						<a href="#amy-winehouse" class="group">
							<div class="flex items-center gap-4">
								<span class="text-xs font-mono text-zinc-500 transition-colors group-hover:text-stone-400">06</span>
								<span class="font-display tracking-widest text-lg text-zinc-300 transition-colors group-hover:text-white">AMY WINEHOUSE</span>
							</div>
							<svg class="w-4 h-4 text-zinc-500 opacity-0 -translate-x-2 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0 group-hover:text-stone-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</a>
					</li>
				</ul>
			</nav>
		</aside>
	</div>
</Layout>

<style>
	@reference "../global.css";

	.hero {
		.hero-title {
