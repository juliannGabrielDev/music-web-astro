---
import { Image } from 'astro:assets';
import Layout from '@/layouts/Layout.astro';

// Import all requested organic shapes
import shapeCookie4 from '@/assets/figures/sided-cookie-4.svg';
import shapeSoftBoom from '@/assets/figures/soft-boom.svg';
import shapeFlower from '@/assets/figures/flower.svg';
import shapeGum from '@/assets/figures/Gum.svg';
import shapeGhost from '@/assets/figures/ghost-ish.svg';
import shapePill from '@/assets/figures/pill.svg';
import shapeCircle from '@/assets/figures/Circle.svg';
import shapeSquare from '@/assets/figures/Square.svg';
import shapeArrow from '@/assets/figures/arrow.svg';
import shapePixelCircle from '@/assets/figures/pixel-circle.svg';
import shapePuffyDiamond from '@/assets/figures/puffy-diamond.svg';
import shapeCookie12 from '@/assets/figures/sided-cookie-12.svg';
import shapeTriangle from '@/assets/figures/triangle.svg';

import Adele from '@/assets/artists/adele.webp';
import AmyWinehouse from '@/assets/artists/amy-winehouse.webp';
import CarlyRaeJepsen from '@/assets/artists/carly-rae-jepsen.webp';
import LadyGaga from '@/assets/artists/lady-gaga.webp';
import LanaDelRey from '@/assets/artists/lana-del-rey.webp';
import MeghanTrainor from '@/assets/artists/meghan-trainor.webp';
import Raye from '@/assets/artists/raye.webp';
import Top from '@/assets/artists/top.webp';
import Twice from '@/assets/artists/twice.webp';
import OliviaDean from '@/assets/artists/olivia-dean.webp';
import ColdPlay from '@/assets/artists/cold-play.webp';
import Pink from '@/assets/artists/pink.webp';
import RobbieWilliams from '@/assets/artists/robbie-williams.webp';
import SpiceGirls from '@/assets/artists/spice-girls.webp';
import BritneySpears from '@/assets/artists/britney-spears.webp';
import Aurora from '@/assets/artists/aurora.webp';
import ConanGray from '@/assets/artists/conan-gray.webp';
import KatyPerry from '@/assets/artists/katy-perry.webp';

import AdeleArtist from '@/assets/artists/adele-artist.webp';
import topArtist from '@/assets/artists/twenty-one-pilots-artist.webp';
import lanaArtist from '@/assets/artists/lana-del-rey-artist.webp';
import rayeArtist from '@/assets/artists/raye-artist.webp';
import katyArtist from '@/assets/artists/katy-perry-artist.webp';
import AmyArtist from '@/assets/artists/amy-winehouse-artist.webp';

const baseSlides = [
	{
		type: 'single',
		shape: shapeCookie12.src,
		img: Adele,
	},
	{
		type: 'single',
		shape: shapePixelCircle.src,
		img: Top,
	},
	{
		type: 'quad',
		items: [
			{
				img: Raye,
				shape: shapeCookie4.src,
			},
			{
				img: AmyWinehouse,
				shape: shapeSoftBoom.src,
			},
			{
				img: CarlyRaeJepsen,
				shape: shapeFlower.src,
			},
			{
				img: LadyGaga,
				shape: shapeGum.src,
			},
		],
	},
	{
		type: 'single',
		shape: shapeGhost.src,
		img: LanaDelRey,
	},
	{
		type: 'quad',
		items: [
			{
				img: SpiceGirls,
				shape: shapeGhost.src,
			},
			{
				img: RobbieWilliams,
				shape: shapePill.src,
			},
			{
				img: Pink,
				shape: shapeCircle.src,
			},
			{
				img: ColdPlay,
				shape: shapeSquare.src,
			},
		],
	},
	{
		type: 'single',
		shape: shapeFlower.src,
		img: OliviaDean,
	},
	{
		type: 'single',
		shape: shapeArrow.src,
		img: MeghanTrainor,
	},
	{
		type: 'quad',
		items: [
			{
				img: KatyPerry,
				shape: shapePixelCircle.src,
			},
			{
				img: BritneySpears,
				shape: shapePuffyDiamond.src,
			},
			{
				img: Aurora,
				shape: shapeCookie12.src,
			},
			{
				img: ConanGray,
				shape: shapeTriangle.src,
			},
		],
	},
	{
		type: 'single',
		shape: shapePill.src,
		img: Twice,
	},
];

const slides = [...baseSlides, ...baseSlides];
---

<Layout>
	<section class="hero">
		<h1 class="h1 pointer-events-none relative z-10 mb-12 uppercase">Artistas</h1>
		<ul class="carousel">
			{
				slides.map((slide, index) => (
					<li class="carousel__item">
						{slide.type === 'single' ? (
							<div
								class={`artist-figure relative flex h-full w-full items-center justify-center overflow-hidden shadow-2xl transition-shadow duration-300`}
								style={`mask-image: url(${slide.shape}); mask-size: contain; mask-repeat: no-repeat; mask-position: center; -webkit-mask-image: url(${slide.shape}); -webkit-mask-size: contain; -webkit-mask-repeat: no-repeat; -webkit-mask-position: center;`}
							>
								<Image
									src={slide.img}
									alt={`Artist ${index + 1}`}
									class="pointer-events-none h-full w-full object-cover"
									draggable="false"
								/>
							</div>
						) : (
							<div class="grid h-full w-full grid-cols-2 grid-rows-2 gap-2 p-1 md:gap-4">
								{slide.items!.map((subItem) => (
									<div
										class="artist-figure relative h-full w-full overflow-hidden shadow-lg"
										style={`mask-image: url(${subItem.shape}); mask-size: contain; mask-repeat: no-repeat; mask-position: center; -webkit-mask-image: url(${subItem.shape}); -webkit-mask-size: contain; -webkit-mask-repeat: no-repeat; -webkit-mask-position: center;`}
									>
										<Image
											src={subItem.img}
											alt={`Artist from group ${index + 1}`}
											class="pointer-events-none h-full w-full object-cover"
											draggable="false"
										/>
									</div>
								))}
							</div>
						)}
					</li>
				))
			}
		</ul>
		<div class="mx-auto mt-16 flex w-full max-w-4xl flex-col items-center px-6">
			<div class="pointer-events-none h-1 w-24 rounded-full bg-yellow-400 opacity-30"></div>

			<p
				class="pointer-events-none mt-8 max-w-sm text-center text-sm leading-relaxed font-semibold tracking-wide text-zinc-300 md:text-base"
			>
				Explora mis artistas favoritos<br />
				Desliza para descubrir más talento musical
			</p>
		</div>
	</section>
	<div class="container">
		<main class="p-6">
			<article id="adele">
				<h2 class="h2">ADELE</h2>
				<p class="p mb-1">
					Adele Laurie Blue Adkins, conocida simplemente como Adele, es una cantautora y multinstrumentista británica.
					Es una de las artistas musicales con mayores ventas del mundo, con más de 120 millones de ventas entre discos
					y sencillos. Desde pequeña mostró interés por la música y en 2006 se egresó de la BRIT School, año en el que
					firmó un contrato con XL Recordings, tras ser descubierta por unos demos que un amigo publicó en la red social
					MySpace. En 2008, lanzó su álbum de estudio debut, 19, el cual se situó en la posición 1 de la lista de
					álbumes británica y ha sido certificado ocho veces platino en Reino Unido y triple platino en Estados Unidos.
				</p>
				<Image src={AdeleArtist} alt="Adele en los Grammys de 2012" class="article__image" />
			</article>
			<article id="top">
				<h2 class="h2">TWENTY ONE PILOTS</h2>
				<p class="p">
					Twenty One Pilots es un dúo musical estadounidense de Columbus, Ohio. La banda se formó en 2009 por el
					vocalista Tyler Joseph junto con Nick Thomas y Chris Salih, quienes la abandonaron en 2011. Desde su partida,
					la formación ha consistido en el cantante Tyler Joseph y el baterista Josh Dun. El grupo es principalmente
					conocido por los sencillos "Stressed Out", "Ride" y "Heathens". El grupo recibió un Premio Grammy al mejor pop
					de dúo/grupo en los Premios Grammy de 2017.
				</p>
				<Image src={topArtist} alt="Twenty One Pilots en Breach" class="article__image" />
			</article>
			<article id="lana-del-rey">
				<h2 class="h2">LANA DEL REY</h2>
				<p class="p">
					Elizabeth Woolridge Grant, conocida artísticamente como Lana Del Rey, es una cantante, compositora, modelo,
					actriz, escritora, productora y poetisa estadounidense. Su música se distingue por su calidad cinematográfica,
					su estilo retro y su exploración del romance trágico, el glamur y la melancolía. Con frecuentes referencias a
					la cultura pop contemporánea y a la época dorada de los años 1950 y 1960 en Estados Unidos.
				</p>
				<Image src={lanaArtist} alt="Lana Del Rey en Born To Die" class="article__image" />
			</article>
			<article id="raye">
				<h2 class="h2">RAYE</h2>
				<p class="p">
					Rachel Agatha Keen, conocida como RAYE, es una cantante y compositora británica. Alcanzó la fama tras la
					publicación en 2016 de una canción de Jonas Blue, «By Your Side», en la que participó como vocalista y tuvo
					gran popularidad en la lista de éxitos musicales de Reino Unido. Su siguiente colaboración, «You Don't Know
					Me» junto con Jax Jones, obtuvo aún mayor notoriedad y se situó en la posición 3 en el listado de sencillos
					británicos.
				</p>
				<Image src={rayeArtist} alt="Retrato de Raye" class="article__image" />
			</article>
			<article id="katy-perry">
				<h2 class="h2">KATY PERRY</h2>
				<p class="p">
					Katheryn Elizabeth Hudson, conocida artísticamente como Katy Perry, es una cantante, actriz, modelo,
					productora discográfica, bailarina, compositora, personalidad de televisión y empresaria estadounidense. Es
					una de las artistas musicales con mayores ventas, con más de 151 millones de unidades vendidas en todo el
					mundo. Ha dejado una influencia en la música pop gracias a su estilo camp, por lo que Vogue y Rolling Stone la
					han apodado la «Reina del Camp».
				</p>
				<Image src={katyArtist} alt="Retrato de Katy Perry" class="article__image" />
			</article>
			<article id="amy-winehouse">
				<h2 class="h2">AMY WINEHOUSE</h2>
				<p class="p">
					Amy Jade Winehouse fue una cantante, compositora y multiinstrumentista británica. Es conocida por su poderosa
					y profunda voz de contralto y su ecléctica mezcla de géneros musicales, que incluyen soul, jazz, R&B y ritmos
					caribeños como el ska. Proveniente de una familia con una fuerte tradición musical ligada al jazz, comenzó su
					carrera artística cuando aún era una adolescente, actuando en pequeños clubes del género en Londres. Su debut
					en la escena musical británica se produjo en 2003 con el álbum Frank, que, aunque elogiado por la crítica
					musical, inicialmente no logró buenas ventas.
				</p>
				<Image src={AmyArtist} alt="Retrato de Amy Winehouse" class="article__image" />
			</article>
		</main>
		<nav class="toc" aria-label="Índice de artistas">
			<ul>
				<li><a href="#adele">ADELE</a></li>
				<li><a href="#top">TWENTY ONE PILOTS</a></li>
				<li><a href="#lana-del-rey">LANA DEL REY</a></li>
				<li><a href="#raye">RAYE</a></li>
				<li><a href="#katy-perry">KATY PERRY</a></li>
				<li><a href="#amy-winehouse">AMY WINEHOUSE</a></li>
			</ul>
		</nav>
	</div>
</Layout>

<style>
	@reference "tailwindcss";

	.hero {
		@apply py-12;

		h1 {
			animation: reveal-title 1s cubic-bezier(0.77, 0, 0.175, 1);
		}
	}
	.container {
		@apply grid mx-auto max-w-7xl gap-6 lg:gap-0;

		@media (width >= 64rem) {
			grid-template-columns: auto 300px;
		}
	}
	main {
		@apply space-y-20 border border-zinc-800 lg:mb-6 order-2 lg:order-1;
	}
	.toc {
		@apply bg-zinc-200 p-4 rounded-3xl lg:sticky lg:top-22 lg:self-start h-fit w-fit ml-6 order-1 lg:order-2;
		scroll-target-group: auto;
		a {
			@apply block rounded-xl px-3 py-2 text-zinc-700 transition-colors;
		}

		a:target-current {
			@apply font-black bg-zinc-800 text-zinc-100;
		}

		ul {
			@apply space-y-1;
		}
	}
	article {
		@apply space-y-6;
	}
	.article__image {
		@apply mx-auto rounded-3xl object-cover;
		width: min(100%, 600px);
	}

	@supports (animation-timeline: view()) {
		.article__image {
			animation: auto linear reveal-image both;
			animation-timeline: view();
			animation-range: entry 15% cover 45%;
		}
	}
	.carousel {
		container-type: scroll-state;
		container-name: carousel;
		@apply grid min-h-65 gap-4 overflow-x-auto md:min-h-105 md:gap-8;
		grid-auto-flow: column;
		align-items: center;
		/* habilita scroll en x */
		overscroll-behavior-x: contain;
		scrollbar-width: none;
		scroll-snap-type: x mandatory;
		scroll-behavior: smooth;
		anchor-name: --carousel;
		padding-inline: calc(50% - 125px);

		@media (width > 768px) {
			padding-inline: calc(50% - 200px);
		}

		> .carousel__item {
			@apply size-60 md:size-100;
			scroll-snap-align: center;
			scroll-snap-stop: always;

			:where(.carousel) & {
				animation:
					offscreen-inert linear both,
					resize linear both;
				animation-timeline: view(x);
			}
		}

		&::scroll-button(*) {
			@apply absolute cursor-pointer border-none transition-all bg-zinc-800 px-3 py-2 text-zinc-200;
			position-anchor: --carousel;
			border-radius: 28px;
			corner-shape: squircle;
		}
		&::scroll-button(left) {
			content: '⬅' / 'Scroll Left';
			margin-left: 16px;
			top: anchor(center);
			left: anchor(left);

			@container carousel not scroll-state(scrollable: left) {
				opacity: 0;
				pointer-events: none;
				transform: translateX(-10px);
			}
		}
		&::scroll-button(right) {
			content: '⮕' / 'Scroll Right';
			margin-right: 16px;
			top: anchor(center);
			right: anchor(right);

			@container carousel not scroll-state(scrollable: right) {
				opacity: 0;
				pointer-events: none;
				transform: translateX(10px);
			}
		}
	}

	@keyframes offscreen-inert {
		entry 0%,
		exit 100% {
			interactivity: inert;
		}

		entry 100%,
		exit 0% {
			interactivity: auto;
		}
	}

	@keyframes resize {
		entry 0%,
		35%,
		65%,
		100% {
			transform: scale(0.6);
		}

		50% {
			transform: scale(1);
		}
	}

	@keyframes reveal-image {
		from {
			opacity: 0;
			transform: translateY(18px) scale(0.96);
			filter: saturate(0.85);
		}

		to {
			opacity: 1;
			transform: translateY(0) scale(1);
			filter: saturate(1);
		}
	}

	@keyframes reveal-title {
		0% {
			clip-path: inset(100% 0 0 0);
		}
		100% {
			clip-path: inset(0 0 0 0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero h1, .article__image {
			animation: none;
		}
	}
</style>
